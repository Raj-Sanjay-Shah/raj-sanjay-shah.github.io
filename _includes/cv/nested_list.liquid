<div class="cv-nested-groups">
  {% for content in entry.contents %}
    <section class="cv-nested-group">
      <h5>{{ content.title }}</h5>
      {% if content.items %}
        <div class="cv-nested-grid">
          {% for subitem in content.items %}
            {% assign subitem_parts = subitem | split: " - " %}
            {% assign subitem_name = subitem_parts | first %}
            {% assign subitem_details = subitem | remove_first: subitem_name | remove_first: " - " %}
            <div class="cv-nested-item">
              {% if subitem_parts.size > 1 %}
                <strong>{{ subitem_name }}</strong>
                <span>{{ subitem_details }}</span>
              {% else %}
                <span>{{ subitem }}</span>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </section>
  {% endfor %}
</div>
